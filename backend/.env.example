# Copy to .env and fill in real values. NEVER commit .env to version control.

# ── Database ───────────────────────────────────────────────────────────────────
MONGO_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net"
DB_NAME="village_db"

# ── CORS ───────────────────────────────────────────────────────────────────────
# Production
CORS_ORIGINS="https://ourlittlevillage.au,https://www.ourlittlevillage.au"
# Dev/staging
# CORS_ORIGINS="https://dev.ourlittlevillage.au,http://localhost:3000"

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="CHANGE_ME_GENERATE_WITH_OPENSSL"

# ── Admin ──────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@ourlittlevillage.au"
ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# ── Email ──────────────────────────────────────────────────────────────────────
RESEND_API_KEY=""
SENDER_EMAIL="hello@ourlittlevillage.au"

# ── Stripe (payments) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_MONTHLY=""
STRIPE_PRICE_ID_ANNUAL=""
