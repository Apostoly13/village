# Copy to .env and fill in real values. NEVER commit .env to version control.

MONGO_URL="mongodb://localhost:27017"
DB_NAME="village_db"

# Comma-separated list of allowed frontend origins (no wildcards in production)
CORS_ORIGINS="https://your-frontend-domain.com"

# Admin account — change before first deploy
ADMIN_EMAIL="admin@thevillage.com"
ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# Generate with: openssl rand -hex 32
JWT_SECRET="CHANGE_ME_GENERATE_WITH_OPENSSL"

# Resend email service
RESEND_API_KEY=""
SENDER_EMAIL="hello@thevillage.com"
