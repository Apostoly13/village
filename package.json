{
  "name": "the-village-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Test harness for The Village platform — DEV environment only",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:dev": "PLAYWRIGHT_BASE_URL=$DEV_FRONTEND_URL playwright test --project=chromium-desktop",
    "test:e2e:mobile": "playwright test --project=iphone-se --project=iphone-12 --project=pixel-5",
    "test:e2e:all-devices": "playwright test",
    "test:e2e:headed": "playwright test --headed --project=chromium-desktop",
    "test:e2e:debug": "playwright test --debug --project=chromium-desktop",
    "test:e2e:report": "playwright show-report test-results/playwright-report",

    "test:api": "python -m pytest tests/api/ -v",
    "test:api:dev": "python -m pytest tests/api/ -v --tb=short",
    "test:api:auth": "python -m pytest tests/api/test_auth.py -v",
    "test:api:security": "python -m pytest tests/api/test_security.py -v",
    "test:api:marketplace": "python -m pytest tests/api/test_marketplace.py -v",
    "test:api:forums": "python -m pytest tests/api/test_forums.py -v",
    "test:api:events": "python -m pytest tests/api/test_events.py -v",
    "test:api:messages": "python -m pytest tests/api/test_messages.py -v",
    "test:api:admin": "python -m pytest tests/api/test_admin.py -v",
    "test:api:notifications": "python -m pytest tests/api/test_notifications.py -v",

    "test:security:dev": "python -m pytest tests/api/test_security.py -v --tb=long",
    "test:mobile:dev": "playwright test --project=iphone-se --project=iphone-12 --project=pixel-5 --project=ipad",

    "test:load:smoke": "python tests/load/load_runner.py --users 5 --duration 60",
    "test:load:baseline": "python tests/load/load_runner.py --users 10 --duration 120",
    "test:load:moderate": "python tests/load/load_runner.py --users 25 --duration 120",
    "test:load:dev": "python tests/load/load_runner.py --users 10 --duration 120",

    "test:cleanup:dev": "python -c \"import sys; sys.path.insert(0,'tests'); from utils.cleanup import cleanup_test_data, print_cleanup_report; print_cleanup_report(cleanup_test_data())\"",

    "test:setup": "python -c \"import sys; sys.path.insert(0,'tests'); from utils.test_users import setup_all_test_users; setup_all_test_users()\"",

    "test:all:dev": "python tests/run_all_tests.py",
    "test:all:dev:skip-load": "python tests/run_all_tests.py --skip-load",

    "playwright:install": "playwright install --with-deps chromium",
    "playwright:install:all": "playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "dotenv": "^16.4.0",
    "typescript": "^5.4.0"
  }
}
